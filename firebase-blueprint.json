{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a chat thread.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The ID of the user who owns the chat." },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Stores chat messages."
    }
  }
}
